# tabi-guide 環境変数テンプレート
#
# このファイルは git にコミットしてよい（実値を書かない！）。
# 実際の値は .env に記入する（.gitignore で除外済み）。

# ============================================================
# クライアント配信に含める値（EXPO_PUBLIC_* 接頭辞）
# ============================================================
# ⚠️ EXPO_PUBLIC_* はアプリバンドルに埋め込まれ、配信先で抽出可能。
# ここには「漏れても害がない値」しか置いてはいけない。
# 例: リファラ/Bundle ID 制限済みの Google Maps API Key、Supabase ANON key (RLS で守られている)。
# ❌ 絶対 NG: Anthropic / OpenAI 等の LLM API キー（制限不能、漏洩 → 第三者課金）

EXPO_PUBLIC_GOOGLE_API_KEY=

# ============================================================
# ローカル管理スクリプト用（NEVER commit、NEVER bundle）
# ============================================================
# 以下はバッチスクリプト (scripts/*.js) でのみ使用。
# 配信物・GitHub Actions・GitHub Secrets には絶対に置かない。
# 漏洩経験 (2026-05-05) を踏まえ、ローカル実行のみで完結させる方針。

# Supabase service_role key (DB 全書き込み権限。最も慎重に)
SUPABASE_KEY=

# Google Cloud TTS API key (WaveNet 音声生成、scripts/generate-tts-audio.js)
GOOGLE_TTS_API_KEY=

# Anthropic Claude API key (英文生成バッチ scripts/generate-english-all.js)
# 注意: 配信アプリの AI チャットは Supabase Edge Function 経由で別管理 (Edge Function secrets)
CLAUDE_API_KEY=

# Google Places API key (data 収集スクリプト用)
GOOGLE_PLACES_API_KEY=
